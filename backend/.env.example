SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DISCORD_BOT_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
PORT=3001

# Discord bot — optional
API_BASE_URL=http://localhost:3001
ALERT_POLL_INTERVAL_MS=15000

# LLM enhancement — optional, behind USE_LLM flag
USE_LLM=false
# Up to 5 API configs (tried in order, max 3 attempts per call).
# Falls back to templates if all fail or USE_LLM=false.
LLM_API_KEY_1=
# LLM_API_URL_1=https://api.openai.com/v1/chat/completions  (default)
# LLM_MODEL_1=gpt-4o-mini                                    (default)
# LLM_API_KEY_2=
# LLM_API_URL_2=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL_2=deepseek-chat
# LLM_API_KEY_3=
# LLM_API_URL_3=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL_3=deepseek/deepseek-chat
# LLM_API_KEY_4=
# LLM_API_URL_4=http://localhost:11434/v1/chat/completions
# LLM_MODEL_4=llama3.2
# LLM_API_KEY_5=
# LLM_API_URL_5=https://api.openai.com/v1/chat/completions
# LLM_MODEL_5=gpt-4o-mini
# The old single LLM_API_KEY / LLM_API_URL / LLM_MODEL still works too (no number).
